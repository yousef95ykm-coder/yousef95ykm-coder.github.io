<form action="https://formspree.io/f/mlgaenkl" method="POST">
    <div class="card">
        <input type="text" name="name" placeholder="الاسم" required>
    </div>
    <div class="card">
        <input type="email" name="email" placeholder="بريدك الإلكتروني" required>
    </div>
    <div class="card">
        <textarea name="message" placeholder="كيف حالك" rows="4" required></textarea>
    </div>
    <button type="submit">إرسال</button>
</form>

